{
  "name": "album",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply album-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply album-db --remote"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.9",
    "@pothos/core": "^4.12.0",
    "drizzle-orm": "^0.45.2",
    "graphql": "^16.14.0",
    "graphql-yoga": "^5.21.0",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "react": "^19.1.7",
    "react-dom": "^19.1.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.41",
    "@types/react": "^19.1.7",
    "@types/react-dom": "^19.1.7",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5.7.4",
    "wrangler": "^4.92.0"
  }
}
